  <!-- Scroll reveal script -->
  <script>
    // Intersection Observer for scroll animations
    const observerOptions = {
      root: null,
      rootMargin: "0px 0px -80px 0px", // Trigger a bit earlier
      threshold: 0.1, // Trigger when 10% of element is visible
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("is-visible");
          observer.unobserve(entry.target);
        }
      });
    }, observerOptions);

    // Observe all scroll-reveal elements.
    document.addEventListener("DOMContentLoaded", () => {
      const revealElements = document.querySelectorAll(".scroll-reveal");
      revealElements.forEach((el) => observer.observe(el));

      const calSelector = "#my-cal-inline-30min";
      const calNamespace = "home30";
      const calRoot = document.querySelector(calSelector);

      if (!calRoot || calRoot.getAttribute("data-cal-ready") === "true") {
        return;
      }

      calRoot.setAttribute("data-cal-ready", "true");

      const configureLenisForCalEmbed = () => {
        const lenis = (window as any).lenis as
          | { stop?: () => void; start?: () => void }
          | undefined;
        if (!lenis) return;

        const stopLenis = () => lenis.stop?.();
        const startLenis = () => lenis.start?.();

        calRoot.addEventListener("mouseenter", stopLenis);
        calRoot.addEventListener("mouseleave", startLenis);
        calRoot.addEventListener("touchstart", stopLenis, { passive: true });
        window.addEventListener("touchend", startLenis, { passive: true });
      };

      (function (C, A, L) {
        const p = function (a, ar) {
          a.q.push(ar);
        };
        const d = C.document;
        C.Cal =
          C.Cal ||
          function () {
            const cal = C.Cal;
            const ar = arguments;
            if (!cal.loaded) {
              cal.ns = {};
              cal.q = cal.q || [];
              d.head.appendChild(d.createElement("script")).src = A;
              cal.loaded = true;
            }
            if (ar[0] === L) {
              const api = function () {
                p(api, arguments);
              };
              const namespace = ar[1];
              api.q = api.q || [];
              if (typeof namespace === "string") {
                cal.ns[namespace] = cal.ns[namespace] || api;
                p(cal.ns[namespace], ar);
                p(cal, ["initNamespace", namespace]);
              } else {
                p(cal, ar);
              }
              return;
            }
            p(cal, ar);
          };
      })(window, "https://app.cal.com/embed/embed.js", "init");

      Cal("init", calNamespace, { origin: "https://app.cal.com" });

      Cal.ns[calNamespace]("inline", {
        elementOrSelector: calSelector,
        config: { layout: "month_view", useSlotsViewOnSmallScreen: true },
        calLink: "bryanjacinto/30min",
      });

      const applyCalTheme = () => {
        const isDark = document.documentElement.classList.contains("dark");
        const pageBg =
          getComputedStyle(document.documentElement)
            .getPropertyValue("--section-bg")
            .trim() || (isDark ? "#000000" : "#ffffff");

        Cal.ns[calNamespace]("ui", {
          hideEventTypeDetails: false,
          layout: "month_view",
          theme: isDark ? "dark" : "light",
          styles: {
            body: { background: pageBg },
          },
        });
      };

      const configureCalIframeScroll = () => {
        const iframe = calRoot.querySelector<HTMLIFrameElement>("iframe");
        if (!iframe || iframe.dataset.scrollConfigured === "true") return;

        iframe.dataset.scrollConfigured = "true";
        iframe.setAttribute("scrolling", "no");
        iframe.style.overflow = "hidden";
      };

      applyCalTheme();
      configureCalIframeScroll();
      configureLenisForCalEmbed();

      const themeObserver = new MutationObserver((mutations) => {
        for (const mutation of mutations) {
          if (mutation.attributeName === "class") {
            applyCalTheme();
            break;
          }
        }
      });

      themeObserver.observe(document.documentElement, {
        attributes: true,
        attributeFilter: ["class"],
      });

      const iframeObserver = new MutationObserver(() => {
        configureCalIframeScroll();
      });

      iframeObserver.observe(calRoot, {
        childList: true,
        subtree: true,
      });
    });
  </script>

  <script>
    const HOME_EMAILJS_SERVICE_ID = import.meta.env.PUBLIC_EMAILJS_SERVICE_ID;
    const HOME_EMAILJS_TEMPLATE_ID = import.meta.env.PUBLIC_EMAILJS_TEMPLATE_ID;
    const HOME_EMAILJS_PUBLIC_KEY = import.meta.env.PUBLIC_EMAILJS_PUBLIC_KEY;

    function initEmailJsForHome() {
      if (!HOME_EMAILJS_PUBLIC_KEY) return;

      if (window.emailjs) {
        window.emailjs.init(HOME_EMAILJS_PUBLIC_KEY);
        return;
      }

      const existing = document.querySelector<HTMLScriptElement>(
        'script[src="https://cdn.jsdelivr.net/npm/@emailjs/browser@4/dist/email.min.js"]',
      );

      if (existing) {
        existing.addEventListener(
          "load",
          () => window.emailjs?.init(HOME_EMAILJS_PUBLIC_KEY),
          { once: true },
        );
        return;
      }

      const script = document.createElement("script");
      script.src =
        "https://cdn.jsdelivr.net/npm/@emailjs/browser@4/dist/email.min.js";
      script.onload = () => window.emailjs?.init(HOME_EMAILJS_PUBLIC_KEY);
      document.head.appendChild(script);
    }

    function setHomeFormMessage(
      node: HTMLElement,
      message: string,
      state: "success" | "error",
    ) {
      node.textContent = message;
      node.dataset.state = state;
      node.hidden = false;
    }

    document.addEventListener("DOMContentLoaded", () => {
      initEmailJsForHome();

      const form = document.getElementById(
        "home-contact-form",
      ) as HTMLFormElement | null;
      const formMessage = document.getElementById("home-form-message");

      if (!form || !formMessage) return;

      form.addEventListener("submit", async (event) => {
        event.preventDefault();

        const submitButton = form.querySelector(
          'button[type="submit"]',
        ) as HTMLButtonElement | null;
        const submitText = document.getElementById("home-submit-text");
        const submitLoading = document.getElementById("home-submit-loading");

        if (!submitButton || !submitText || !submitLoading) return;

        submitButton.disabled = true;
        submitText.classList.add("hidden");
        submitLoading.classList.remove("hidden");
        formMessage.hidden = true;

        try {
          const formData = new FormData(form);
          const data = Object.fromEntries(formData.entries());

          if (!data.name || !data.email || !data.message) {
            throw new Error("Name, email, and message are required.");
          }

          const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
          if (!emailRegex.test(data.email as string)) {
            throw new Error("Please provide a valid email address.");
          }

          if (!window.emailjs) {
            throw new Error("EmailJS is still loading. Please try again.");
          }

          await window.emailjs.send(
            HOME_EMAILJS_SERVICE_ID,
            HOME_EMAILJS_TEMPLATE_ID,
            {
              from_name: data.name,
              from_email: data.email,
              phone: data.phone || "Not provided",
              message: data.message,
              to_email: "jacintobryan3@gmail.com",
            },
          );

          setHomeFormMessage(
            formMessage,
            "Thank you! Your message has been sent successfully. I'll get back to you shortly.",
            "success",
          );
          form.reset();
        } catch (error) {
          console.error("Home contact form error:", error);
          setHomeFormMessage(
            formMessage,
            "Sorry, there was an issue sending your message. Please try again or email me at jacintobryan3@gmail.com.",
            "error",
          );
        } finally {
          submitButton.disabled = false;
          submitText.classList.remove("hidden");
          submitLoading.classList.add("hidden");
          formMessage.hidden = false;
        }
      });
    });
  </script>
</BaseLayout>
