---

<BaseLayout
  title="Bryan Jacinto - Copy & SEO"
  description="Copywriting, editing, B2B content, and SEO-focused writing."
>
  <section
    class="hero-section flex items-center justify-center text-[var(--color-text)]"
    data-hero
  >
    <div class="w-full max-w-6xl mx-auto px-5 sm:px-6">
      <div
        class="hero-content-wrap mx-auto w-full max-w-4xl flex flex-col items-center text-center gap-5 sm:gap-6"
      >
        <div
          class="hero-avatar-wrap"
          data-hero-avatar
          data-hero-animate
        >
          <img
            src="/Bryan_hero_image.webp"
            alt="Bryan Jacinto"
            class="hero-avatar-image"
            loading="eager"
            fetchpriority="high"
            width="96"
            height="96"
          />
        </div>

        <h1 class="hero hero-main-title" data-hero-title data-hero-animate>
          Hi, I'm Bryan Jacinto 👋
        </h1>

        <ul
          class="flex flex-wrap items-center justify-center gap-2.5"
          data-hero-roles
        >
          {
            roles.map((r) => (
              <li
                class="role-badge inline-flex items-center gap-2 rounded-md
                     px-3.5 py-1.5
                     text-[12.5px] sm:text-[13px] font-medium tracking-tight
                     text-[var(--color-text)]
                     bg-[var(--surface-glass)]
                     border border-[var(--color-border)]
                     ring-1 ring-[#0E335733] dark:ring-[#86B7FF2D]
                     shadow-sm
                     transition-all duration-300 ease-out
                     cursor-default"
                data-hero-animate
              >
                <span class="role-badge-dot h-1.5 w-1.5 rounded-full bg-current/50 transition-all duration-300" />
                {r}
              </li>
            ))
          }
        </ul>

        <p
          class="text-[15px] sm:text-base md:text-[17px] leading-relaxed text-[var(--color-muted)] max-w-3xl mx-auto"
          data-hero-text
          data-hero-animate
        >
          Copywriter with seven years of experience creating SEO content, blog
          posts, landing pages, and marketing copy for global clients.
          Currently crafting meaningful content for <a
            href="https://www.mobiloud.com/"
            target="_blank"
            rel="noopener noreferrer"
            class="text-[var(--color-text)] font-medium hover:text-[var(--color-accent)] transition-colors duration-200 underline decoration-1 underline-offset-2"
            >Mobiloud</a
          >, <a
            href="https://www.monok.com/"
            target="_blank"
            rel="noopener noreferrer"
            class="text-[var(--color-text)] font-medium hover:text-[var(--color-accent)] transition-colors duration-200 underline decoration-1 underline-offset-2"
            >Monok</a
          >, and <a
            href="https://thefriendlyskies.net/"
            target="_blank"
            rel="noopener noreferrer"
            class="text-[var(--color-text)] font-medium hover:text-[var(--color-accent)] transition-colors duration-200 underline decoration-1 underline-offset-2"
            >The Friendly Skies</a
          >.
        </p>

        <div
          class="flex flex-col sm:flex-row items-center justify-center gap-3 pt-2"
        >
          <a
            href="/work"
            class="btn-primary work-cta-button inline-flex h-11 items-center justify-center rounded-full px-6 text-sm font-semibold transition-all duration-200 w-full sm:w-auto"
            data-hero-cta
            data-hero-animate
            aria-label="See my work"
          >
            <span class="work-cta-swap" aria-hidden="true">
              <span class="work-cta-front">See my work</span>
              <span class="work-cta-back">
                <svg
                  class="work-cta-arrow-icon"
                  viewBox="0 0 24 24"
                  aria-hidden="true"
                >
                  <path d="M5 12h14"></path>
                  <path d="M13 7l6 5-6 5"></path>
                </svg>
              </span>
            </span>
          </a>
          <a
            href="/contact"
            class="snake-border-button book-call-button group inline-flex h-11 items-center justify-center rounded-full px-6 text-sm font-semibold focus:outline-none w-full sm:w-auto"
            data-hero-cta
            data-hero-animate
            aria-label="Book a call"
          >
            <span class="book-call-swap" aria-hidden="true">
              <span class="book-call-front">Book a Call</span>
              <span class="book-call-back">
                <img
                  src="/Bryan_hero_image.webp"
                  alt=""
                  class="book-call-avatar"
                  loading="lazy"
                  decoding="async"
                  width="24"
                  height="24"
                />
                <span class="book-call-plus">+</span>
                <span class="book-call-you">YOU</span>
              </span>
            </span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <script>
    const initHeroGsap = async () => {
      const hero = document.querySelector("[data-hero]");
      if (!hero) return;

      const prefersReducedMotion = window.matchMedia(
        "(prefers-reduced-motion: reduce)",
      );
      if (prefersReducedMotion.matches) {
        hero
          .querySelectorAll<HTMLElement>(
            "[data-hero-animate], [data-hero-roles] li",
          )
          .forEach((el) => {
            el.style.opacity = "1";
            el.style.transform = "none";
          });
        hero.setAttribute("data-hero-ready", "");
        return;
      }

      try {
        const [{ gsap }, { ScrollTrigger }] = await Promise.all([
          import("gsap"),
          import("gsap/ScrollTrigger"),
        ]);

        gsap.registerPlugin(ScrollTrigger);

        const heroTitle = hero.querySelector("[data-hero-title]");
        const heroAvatar = hero.querySelector("[data-hero-avatar]");
        const roleItems = hero.querySelectorAll("[data-hero-roles] li");
        const heroText = hero.querySelector("[data-hero-text]");
        const heroCtas = hero.querySelectorAll("[data-hero-cta]");
        const heroImage = hero.querySelector("[data-hero-image]");
        const animatedNodes = hero.querySelectorAll("[data-hero-animate]");

        gsap.set(animatedNodes, { opacity: 0, y: 20 });
        gsap.set(roleItems, { opacity: 0, y: 15 });
        if (heroImage) {
          gsap.set(heroImage, { opacity: 0, y: 30, rotate: -3 });
        }

        hero.setAttribute("data-hero-ready", "");

        const tl = gsap.timeline({
          defaults: { ease: "power3.out" },
          // No ScrollTrigger - animations start immediately for initial viewport
        });

        if (heroAvatar) {
          tl.to(heroAvatar, { opacity: 1, y: 0, duration: 0.35 });
        }

        if (heroTitle) {
          tl.to(heroTitle, { opacity: 1, y: 0, duration: 0.4 }, "-=0.08");
        }

        if (roleItems.length) {
          tl.to(
            roleItems,
            {
              opacity: 1,
              y: 0,
              duration: 0.3,
              stagger: 0.04,
            },
            "-=0.35",
          );
        }

        if (heroText) {
          tl.to(
            heroText,
            { opacity: 1, y: 0, duration: 0.35 },
            roleItems.length ? "-=0.25" : "-=0.3",
          );
        }

        if (heroCtas.length) {
          tl.to(
            heroCtas,
            {
              opacity: 1,
              y: 0,
              duration: 0.3,
              stagger: 0.08,
            },
            "-=0.25",
          );
        }

        if (heroImage) {
          const addAt = heroCtas.length ? "-=0.3" : "-=0.25";
          tl.to(
            heroImage,
            { opacity: 1, y: 0, rotate: 0, duration: 0.5, ease: "power3.out" },
            addAt,
          );
        }
      } catch (error) {
        console.warn("Hero animation failed to load GSAP", error);
        hero
          .querySelectorAll<HTMLElement>(
            "[data-hero-animate], [data-hero-roles] li",
          )
          .forEach((el) => {
            el.style.opacity = "1";
            el.style.transform = "none";
          });
        hero.setAttribute("data-hero-ready", "");
      }
    };

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", initHeroGsap, {
        once: true,
      });
    } else {
      initHeroGsap();
    }
  </script>

  <!-- Experience section with Card Stack -->
  <section
    id="my-experiences"
    class="page-section scroll-mt-[70px] md:scroll-mt-[23.5px] flex items-start justify-center text-[var(--color-text)]"
  >
    <div class="mx-auto max-w-6xl px-4 sm:px-5 md:px-6 w-full">
      <!-- Section Header -->
      <div class="scroll-reveal scroll-reveal-item text-center mb-8">
        <h2 class="mb-0">My Experience</h2>
      </div>

      <!-- Card Stack Component -->
      <div class="scroll-reveal scroll-reveal-item scroll-reveal-delay-1">
        <CardStack
          cards={experienceCards}
          cardWidth="650px"
          cardHeight="300px"
          stackShift={60}
          stackScale={0.05}
          enterRotation={6}
          enterOpacity={0.7}
          transitionDuration={400}
        />
      </div>
    </div>
  </section>

  <!-- Client Testimonials Section -->
  <section class="page-section">
    <div class="mx-auto max-w-6xl px-4 sm:px-5 md:px-6 w-full">
      <div class="scroll-reveal scroll-reveal-item text-center mb-8">
        <h2 class="mb-0">What Clients Say</h2>
      </div>
      <TestimonialGrid testimonials={clientTestimonials} />
    </div>
  </section>

  <!-- My Toolset Section -->
  <section class="page-section flex items-center">
    <div class="mx-auto max-w-6xl px-4 sm:px-5 md:px-6 w-full">
      <div class="scroll-reveal scroll-reveal-item text-center mb-8">
        <h2 class="mb-0">My Toolset</h2>
      </div>
      <ToolsetGrid tools={toolsetData} />
    </div>
  </section>

  <!-- Book a Call Inline Calendar -->
  <section class="page-section">
    <div class="mx-auto max-w-6xl px-4 sm:px-5 md:px-6 w-full">
      <div class="scroll-reveal scroll-reveal-item">
        <div id="my-cal-inline-30min" class="cal-inline-embed"></div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="cta-section">
    <div class="mx-auto max-w-4xl px-4 sm:px-5 md:px-6 text-center">
      <div class="scroll-reveal scroll-reveal-item mb-8">
        <h2 class="mb-6">Ready to Work Together?</h2>
        <p
          class="text-[var(--color-muted)] mb-6 text-base sm:text-lg max-w-2xl mx-auto"
        >
          I'm always excited to collaborate on new projects. Whether you need
          copywriting, content strategy, SEO-focused writing, or full stack
          development, let's discuss how I can help bring your ideas to life.
        </p>
        <div
          class="flex flex-col sm:flex-row items-center justify-center gap-3 sm:gap-4"
        >
          <a
            href="/contact"
            class="btn-primary inline-flex h-11 sm:h-12 items-center justify-center rounded-full px-6 sm:px-8 text-sm sm:text-base font-semibold transition-all duration-200 w-full sm:w-auto"
          >
            Get in touch
          </a>
          <a
            href="/work"
            class="snake-border-button group inline-flex h-11 sm:h-12 items-center justify-center rounded-full px-6 sm:px-8 text-sm sm:text-base font-semibold focus:outline-none w-full sm:w-auto"
            aria-label="View my work"
          >
            <span>View my work</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Smooth scroll (no visual style changes) -->
  <style is:global>
    html {
      scroll-behavior: smooth;
    }

    /* Scroll reveal animations */
    .scroll-reveal {
      opacity: 0;
      transform: translateY(40px);
      transition:
        opacity 0.8s ease-out,
        transform 0.8s ease-out;
    }

    .scroll-reveal.is-visible {
      opacity: 1;
      transform: translateY(0);
    }

    /* Individual items within sections */
    .scroll-reveal-item {
      opacity: 0;
      transform: translateY(30px);
      transition:
        opacity 0.6s ease-out,
        transform 0.6s ease-out;
    }

    .scroll-reveal.is-visible .scroll-reveal-item {
      opacity: 1;
      transform: translateY(0);
    }

    /* Staggered delays for multiple items */
    .scroll-reveal.is-visible .scroll-reveal-delay-1 {
      transition-delay: 0.15s;
    }

    .scroll-reveal.is-visible .scroll-reveal-delay-2 {
      transition-delay: 0.3s;
    }

    .scroll-reveal.is-visible .scroll-reveal-delay-3 {
      transition-delay: 0.45s;
    }
  </style>

  <style>
    /* Hero section with mathematically perfect positioning */
    .hero-section {
      min-height: calc(100vh - 88px) !important;
      padding: clamp(1.4rem, 2.6vw, 2.2rem) 0 !important;
      margin-top: -88px !important; /* Compensate for BaseLayout's pt-[88px] on smooth-content */
      background-color: var(--section-bg);
      display: flex !important;
      align-items: center !important;
      justify-content: center !important;
    }

    .hero-content-wrap {
      padding-top: 0;
    }

    .hero-main-title {
      margin: 0;
      max-width: 20ch;
      line-height: 1.12;
      font-size: clamp(1.9rem, 4.2vw, 3rem) !important;
    }

