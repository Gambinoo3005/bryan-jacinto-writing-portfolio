---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const projects = (await getCollection("projects", ({ data }) => !data.draft)).sort(
  (a, b) => {
    if (a.data.featured !== b.data.featured) return a.data.featured ? -1 : 1;
    return +b.data.pubDate - +a.data.pubDate;
  },
);
---

<BaseLayout
  title="Projects - Bryan Jacinto"
  description="Things I've built: web apps, AI bots, and full-stack projects, with live demos and source code."
>
  <section
    class="w-full min-h-screen"
    style="background-color: var(--section-bg); margin-top: -88px;"
  >
    <div class="mx-auto max-w-6xl px-5 sm:px-6 pt-24 pb-16">
      <!-- Header -->
      <div class="mb-10">
        <h1 class="mb-4 text-4xl font-bold">Projects</h1>
        <p class="text-[var(--color-muted)] text-lg max-w-2xl">
          The other half of what I do. Web apps, AI bots, and full-stack builds I've
          designed, coded, and shipped, with live demos and source code where I can
          share it.
        </p>
      </div>

      <!-- Project Cards -->
      {projects.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {projects.map((project) => (
            <article class="project-card group">
              <a href={`/projects/${project.slug}`} class="block h-full">
                <div class="h-full flex flex-col rounded-2xl border-2 border-[var(--color-border)] bg-[var(--color-surface)] overflow-hidden shadow-sm transition-all duration-300 hover:shadow-xl hover:border-[var(--color-link)] hover:-translate-y-1 min-h-[26rem]">
                  {project.data.heroImage ? (
                    <div class="relative w-full h-48 overflow-hidden bg-[var(--surface-glass)]">
                      <img
                        src={project.data.heroImage}
                        alt={project.data.title}
                        class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
                        loading="lazy"
                      />
                    </div>
                  ) : (
                    <div class="relative w-full h-48 flex items-center justify-center bg-gradient-to-br from-[var(--color-accent)] to-[var(--color-link)]">
                      <span class="text-3xl font-extrabold text-white/90 tracking-tight px-4 text-center">
                        {project.data.title}
                      </span>
                    </div>
                  )}

                  <div class="flex-1 flex flex-col p-5">
                    <div class="flex flex-wrap items-center gap-2 mb-3 text-xs text-[var(--color-muted)]">
                      {project.data.status && (
                        <span class="px-2 py-1 rounded-full bg-[var(--surface-glass)] border border-[var(--color-border)] font-semibold uppercase tracking-wide">
                          {project.data.status}
                        </span>
                      )}
                      {project.data.year && <span>{project.data.year}</span>}
                    </div>

                    <h2 class="card-title mb-2 text-[var(--color-text)] group-hover:text-[var(--color-link)] transition-colors">
                      {project.data.title}
                    </h2>

                    <p class="text-sm text-[var(--color-muted)] mb-4">
                      {project.data.summary}
                    </p>

                    {project.data.stack.length > 0 && (
                      <ul class="flex flex-wrap gap-1.5 mb-5 list-none p-0">
                        {project.data.stack.slice(0, 4).map((s) => (
                          <li class="px-2 py-0.5 text-[11px] font-medium rounded-md bg-[var(--surface-glass)] border border-[var(--color-border)] text-[var(--color-muted)]">
                            {s}
                          </li>
                        ))}
                      </ul>
                    )}

                    <div class="mt-auto">
                      <div class="flex items-center gap-2 text-sm font-semibold text-[var(--color-link)] group-hover:gap-3 transition-all">
                        <span>View project</span>
                        <svg
                          class="h-4 w-4 transition-transform group-hover:translate-x-1"
                          viewBox="0 0 20 20"
                          fill="currentColor"
                        >
                          <path
                            fill-rule="evenodd"
                            d="M7.21 14.77a.75.75 0 01.02-1.06L11.168 10 7.23 6.29a.75.75 0 111.04-1.08l4.5 4.25a.75.75 0 010 1.08l-4.5 4.25a.75.75 0 01-1.06-.02z"
                            clip-rule="evenodd"
                          />
                        </svg>
                      </div>
                    </div>
                  </div>
                </div>
              </a>
            </article>
          ))}
        </div>
      ) : (
        <div class="text-center py-16">
          <p class="text-[var(--color-muted)] text-lg">
            No projects yet. Check back soon!
          </p>
        </div>
      )}
    </div>
  </section>

  <style>
    .project-card .card-title {
      font-size: 1.25rem;
      line-height: 1.4;
      font-weight: 700;
    }
  </style>
</BaseLayout>
