---
export interface Props {
  tools: Array<{
    id: string;
    name: string;
    category: string;
    icon?: string;
  }>;
}

const { tools } = Astro.props;

const toolsByCategory = tools.reduce<Record<string, Props["tools"][number][]>>(
  (acc, tool) => {
    if (!acc[tool.category]) {
      acc[tool.category] = [];
    }
    acc[tool.category].push(tool);
    return acc;
  },
  {},
);

const categories = Object.entries(toolsByCategory);
---

<div class="toolset-accordion" id="toolset-grid">
  {
    categories.map(([category, categoryTools]) => (
      <details
        class="toolset-dropdown"
        data-category-item
      >
        <summary class="toolset-summary">
          <span class="toolset-summary-left">
            <span class="toolset-summary-title">{category}</span>
          </span>
          <span class="toolset-summary-meta">
            <span class="toolset-count">{categoryTools.length}</span>
            <svg
              class="toolset-chevron"
              viewBox="0 0 20 20"
              fill="none"
              stroke="currentColor"
              aria-hidden="true"
            >
              <path
                d="M6 8l4 4 4-4"
                stroke-width="1.8"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
            </svg>
          </span>
        </summary>

        <div class="toolset-panel">
          <ol class="toolset-list" role="list">
            {
              categoryTools.map((tool) => (
                <li class="toolset-list-item" data-tool-id={tool.id}>
                  <span class="toolset-tool-icon" aria-hidden="true">
                    {tool.icon ? (
                      <img
                        src={`/toolset-icons/${tool.icon}`}
                        alt=""
                        loading="lazy"
                        decoding="async"
                      />
                    ) : (
                      <span class="toolset-tool-icon-placeholder">
                        {tool.name.charAt(0).toUpperCase()}
                      </span>
                    )}
                  </span>
                  <span class="toolset-name">{tool.name}</span>
                </li>
              ))
            }
          </ol>
        </div>
      </details>
    ))
  }
</div>

<style>
  .toolset-accordion {
    max-width: 860px;
    margin: 0 auto;
    display: grid;
    gap: 0.8rem;
  }

  .toolset-dropdown {
    background: color-mix(in srgb, var(--card-bg) 88%, transparent);
    border: 1px solid var(--color-border);
    border-radius: 14px;
    overflow: clip;
    box-shadow: 0 1px 2px color-mix(in srgb, var(--color-text) 10%, transparent);
  }

  .toolset-summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    padding: 0.82rem 0.98rem;
    cursor: pointer;
    user-select: none;
    list-style: none;
    transition: background-color 0.2s ease;
  }

  .toolset-summary::-webkit-details-marker {
    display: none;
  }

  .toolset-summary:hover {
    background: color-mix(in srgb, var(--surface-glass) 92%, transparent);
  }

  .toolset-summary-left {
    display: inline-flex;
    align-items: center;
    gap: 0;
  }

  .toolset-summary-title {
    font-size: 1.02rem;
    font-weight: 700;
    color: var(--color-heading);
    letter-spacing: 0.01em;
    text-align: left;
  }

  .toolset-summary-meta {
    display: inline-flex;
    align-items: center;
    gap: 0.52rem;
    color: var(--color-muted);
  }

  .toolset-count {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 1.4rem;
    height: 1.4rem;
    padding: 0 0.35rem;
    border-radius: 999px;
    font-size: 0.72rem;
    font-weight: 700;
    line-height: 1;
    border: 1px solid color-mix(in srgb, var(--color-border) 90%, transparent);
    background: var(--surface-glass);
  }

  .toolset-chevron {
    width: 0.95rem;
    height: 0.95rem;
    transition: transform 0.22s ease;
  }

  .toolset-dropdown[open] .toolset-chevron {
    transform: rotate(180deg);
  }

  .toolset-panel {
    padding: 0.72rem 0.98rem 0.95rem;
    border-top: 1px solid color-mix(in srgb, var(--color-border) 82%, transparent);
  }

  .toolset-list {
    margin: 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 0.5rem;
  }

  .toolset-list-item {
    display: grid;
    grid-template-columns: auto 1fr;
    align-items: center;
    gap: 0.68rem;
    padding: 0.1rem 0;
  }

  .toolset-tool-icon {
    width: 1.75rem;
    height: 1.75rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 0.5rem;
    border: 1px solid color-mix(in srgb, var(--color-border) 86%, transparent);
    background: color-mix(in srgb, var(--surface-glass) 94%, transparent);
    flex-shrink: 0;
    overflow: hidden;
  }

  .toolset-tool-icon img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 4px;
  }

  .toolset-tool-icon-placeholder {
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--color-muted);
    line-height: 1;
  }

  .toolset-name {
    font-size: 0.96rem;
    font-weight: 500;
    color: color-mix(in srgb, var(--color-text) 88%, var(--color-muted) 12%);
    line-height: 1.35;
    text-align: left;
    transition: color 0.2s ease;
  }

  .toolset-list-item:hover .toolset-name {
    color: var(--color-heading);
  }

  @media (max-width: 480px) {
    .toolset-summary {
      padding: 0.74rem 0.8rem;
    }

    .toolset-summary-title {
      font-size: 0.94rem;
    }

    .toolset-panel {
      padding: 0.64rem 0.8rem 0.84rem;
    }

    .toolset-tool-icon {
      width: 1.62rem;
      height: 1.62rem;
    }

    .toolset-name {
      font-size: 0.9rem;
    }
  }
</style>

<script>
  const dropdowns = document.querySelectorAll<HTMLDetailsElement>(
    "[data-category-item]",
  );

  dropdowns.forEach((dropdown) => {
    dropdown.addEventListener("toggle", () => {
      if (!dropdown.open) return;
      dropdowns.forEach((other) => {
        if (other !== dropdown) other.open = false;
      });
    });
  });
</script>
