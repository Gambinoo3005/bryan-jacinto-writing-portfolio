---
import BaseLayout from "./BaseLayout.astro";
import TableOfContents from "../components/TableOfContents.astro";
import type { MarkdownHeading } from "astro";

interface Props {
  title?: string;
  description?: string;
  pubDate?: Date;
  tags?: string[];
  ogImage?: string;
  heroImage?: string;
  liveUrl?: string;
  repoUrl?: string;
  stack?: string[];
  role?: string;
  year?: string;
  status?: string;
  headings?: MarkdownHeading[];
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title = "Untitled",
  description = "",
  pubDate,
  ogImage,
  heroImage,
  liveUrl,
  repoUrl,
  stack = [],
  role,
  year,
  status,
  headings = [],
  jsonLd,
} = Astro.props;

const metaBits = [role, year, status].filter(Boolean) as string[];
---

<BaseLayout
  title={title}
  description={description}
  ogImage={ogImage}
  showProgressBar={true}
  heroHeader={true}
  jsonLd={jsonLd}
>
  <!-- Hero Section -->
  <section class="project-hero">
    <div class="hero-overlay"></div>
    {heroImage && (
      <img
        src={heroImage}
        alt={title}
        class="hero-image"
        loading="eager"
        fetchpriority="high"
      />
    )}

    <div class="hero-content">
      <div class="hero-inner">
        <div class="hero-badge-spacer" aria-hidden="true"></div>

        <h1 class="hero-title">{title}</h1>

        {metaBits.length > 0 && (
          <div class="hero-meta">
            {metaBits.map((bit, i) => (
              <>
                {i > 0 && <span class="meta-divider">•</span>}
                <span class="meta-item">{bit}</span>
              </>
            ))}
          </div>
        )}

        {stack.length > 0 && (
          <ul class="stack-row" aria-label="Tech stack">
            {stack.map((item) => (
              <li class="stack-badge">{item}</li>
            ))}
          </ul>
        )}

        <p class="hero-description">{description}</p>

        {(liveUrl || repoUrl) && (
          <div class="hero-cta">
            {liveUrl && (
              <a
                href={liveUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="project-btn project-btn-primary"
              >
                Visit live site
                <svg class="btn-icon" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M5 12h14"></path>
                  <path d="M13 7l6 5-6 5"></path>
                </svg>
              </a>
            )}
            {repoUrl && (
              <a
                href={repoUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="project-btn"
              >
                <svg class="btn-gh" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.694-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0 0 22 12.017C22 6.484 17.522 2 12 2z"></path>
                </svg>
                View on GitHub
              </a>
            )}
          </div>
        )}
      </div>
    </div>
  </section>

  <!-- Project Content -->
  <article class="project-article">
    <div class={`article-container ${headings.length > 0 ? "with-sidebar" : ""}`}>
      {headings.length > 0 && (
        <aside class="sidebar hidden lg:block">
          <TableOfContents headings={headings} />
        </aside>
      )}

      <div class="content-wrapper">
        <div class="prose">
          <slot />
        </div>

        <div class="article-footer">
          <a href="/projects" class="back-link">
            <svg class="back-icon" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M12.79 5.23a.75.75 0 01-.02 1.06L8.832 10l3.938 3.71a.75.75 0 11-1.04 1.08l-4.5-4.25a.75.75 0 010-1.08l4.5-4.25a.75.75 0 011.06.02z" clip-rule="evenodd"/>
            </svg>
            Back to Projects
          </a>
        </div>
      </div>
    </div>
  </article>

  <style>
    /* Hero Section */
    .project-hero {
      position: relative;
      width: 100%;
      min-height: 400px;
      display: flex;
      align-items: flex-start;
      justify-content: center;
      background: var(--section-bg);
      overflow: visible;
      padding: 2rem 1rem 6rem 1rem;
      margin-top: -88px;
    }

    .hero-image {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      opacity: 0.15;
      z-index: 0;
    }

    .hero-overlay {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: linear-gradient(
        to bottom,
        transparent 0%,
        transparent 50%,
        var(--section-bg) 90%,
        var(--section-bg) 100%
      );
      z-index: 1;
    }

    .hero-content {
      position: relative;
      z-index: 2;
      width: 100%;
      max-width: 1024px;
      margin: 0 auto;
      padding: 3rem 1.5rem;
    }

    .hero-inner {
      text-align: center;
    }

    .hero-badge-spacer {
      height: 3.9rem;
    }

    .hero-title {
      font-size: clamp(2rem, 5vw, 3.5rem);
      font-weight: 800;
      line-height: 1.2;
      margin-bottom: 1.25rem;
      color: var(--color-heading);
      letter-spacing: -0.02em;
    }

    .hero-meta {
      display: flex;
      align-items: center;
      justify-content: center;
      flex-wrap: wrap;
      gap: 0.75rem;
      margin-bottom: 1.25rem;
      font-size: 0.95rem;
      color: var(--color-muted);
    }

    .meta-divider {
      opacity: 0.5;
    }

    .stack-row {
      list-style: none;
      padding: 0;
      margin: 0 auto 1.5rem auto;
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 0.5rem;
      max-width: 640px;
    }

    .stack-badge {
      padding: 0.3rem 0.75rem;
      font-size: 0.8rem;
      font-weight: 600;
      color: var(--color-text);
      background: var(--surface-glass);
      border: 1px solid var(--color-border);
      border-radius: 9999px;
    }

    .hero-description {
      font-size: 1.125rem;
      line-height: 1.7;
      color: var(--color-muted);
      max-width: 700px;
      margin: 0 auto 1.75rem auto;
    }

    .hero-cta {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 0.75rem;
    }

    .project-btn {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.7rem 1.4rem;
      font-size: 0.95rem;
      font-weight: 600;
      border-radius: 9999px;
      text-decoration: none;
      border: 1px solid var(--color-border);
      background: var(--surface-glass);
      color: var(--color-text);
      transition: all 0.2s ease;
    }

    .project-btn:hover {
      transform: translateY(-2px);
      border-color: var(--color-link);
    }

    .project-btn-primary {
      background: var(--color-link);
      color: #fff;
      border-color: var(--color-link);
    }

    :global(.dark) .project-btn-primary {
      background: #fff;
      color: #000;
      border-color: #fff;
    }

    .btn-icon {
      width: 1.1rem;
      height: 1.1rem;
      fill: none;
      stroke: currentColor;
      stroke-width: 2;
      stroke-linecap: round;
      stroke-linejoin: round;
    }

    .btn-gh {
      width: 1.15rem;
      height: 1.15rem;
    }

    /* Article Content */
    .project-article {
      position: relative;
      z-index: 10;
      background-color: var(--section-bg);
      padding: 0 1rem 4rem 1rem;
      margin-top: -4rem;
    }

    .article-container {
      max-width: 880px;
      margin: 0 auto;
    }

    .article-container.with-sidebar {
      max-width: 1280px;
      display: grid;
      grid-template-columns: minmax(0, 1fr);
      gap: 3rem;
    }

    @media (min-width: 1024px) {
      .article-container.with-sidebar {
        grid-template-columns: 240px minmax(0, 1fr);
        align-items: start;
      }
    }

    .sidebar {
      position: sticky;
      top: 120px;
    }

    .content-wrapper {
      width: 100%;
      min-width: 0;
      max-width: 800px;
      margin: 0 auto;
    }

    /* Prose Styles */
    .prose {
      color: var(--color-text);
      font-size: 1.0625rem;
      line-height: 1.8;
      max-width: 100%;
      margin: 0 auto;
      font-family: var(--font-serif);
      overflow-wrap: break-word;
    }

    .prose :global(h2) {
      font-size: 2rem;
      font-weight: 700;
      margin-top: 3rem;
      margin-bottom: 1.5rem;
      color: var(--color-heading);
      letter-spacing: -0.01em;
    }

    .prose :global(h3) {
      font-size: 1.5rem;
      font-weight: 600;
      margin-top: 2.5rem;
      margin-bottom: 1rem;
      color: var(--color-heading);
    }

    .prose :global(p) {
      margin-bottom: 1.5rem;
    }

    .prose :global(a) {
      color: var(--color-link);
      text-decoration: underline;
      transition: opacity 0.2s ease;
    }

    .prose :global(a:hover) {
      opacity: 0.8;
    }

    .prose :global(ul),
    .prose :global(ol) {
      margin-bottom: 1.5rem;
      padding-left: 1.5rem;
    }

    .prose :global(li) {
      margin-bottom: 0.5rem;
    }

    .prose :global(blockquote) {
      margin: 2rem 0;
      padding: 1.5rem;
      border-left: 4px solid var(--color-link);
      background: var(--surface-glass);
      font-style: italic;
      color: var(--color-muted);
    }

    .prose :global(code) {
      padding: 0.2rem 0.4rem;
      background: var(--surface-glass);
      border: 1px solid var(--color-border);
      border-radius: 0.25rem;
      font-size: 0.9em;
      font-family: 'Courier New', monospace;
    }

    .prose :global(pre) {
      margin: 2rem 0;
      padding: 1.5rem;
      background: var(--surface-glass);
      border: 1px solid var(--color-border);
      border-radius: 0.5rem;
      max-width: 100%;
      overflow-x: auto;
    }

    .prose :global(pre code) {
      padding: 0;
      background: none;
      border: none;
    }

    .prose :global(img) {
      margin: 2rem 0;
      border-radius: 0.5rem;
      max-width: 100%;
      height: auto;
    }

    /* Article Footer */
    .article-footer {
      margin-top: 4rem;
      padding-top: 2rem;
      border-top: 1px solid var(--color-border);
    }

    .back-link {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.75rem 1.5rem;
      font-size: 0.95rem;
      font-weight: 600;
      color: var(--color-text);
      background: var(--surface-glass);
      border: 1px solid var(--color-border);
      border-radius: 9999px;
      transition: all 0.2s ease;
      text-decoration: none;
    }

    .back-link:hover {
      background: var(--color-link);
      color: white;
      border-color: var(--color-link);
      transform: translateX(-4px);
    }

    .dark .back-link:hover {
      background: color-mix(in srgb, var(--color-link) 32%, var(--color-bg) 68%);
      color: var(--color-text);
      border-color: color-mix(in srgb, var(--color-link) 72%, var(--color-bg) 28%);
    }

    .back-icon {
      width: 1.25rem;
      height: 1.25rem;
    }

    /* Responsive */
    @media (max-width: 768px) {
      .hero-content {
        padding: 2rem 1rem;
      }

      .hero-title {
        font-size: 2rem;
      }

      .project-article {
        padding: 2rem 1rem;
      }

      .prose {
        font-size: 1rem;
      }
    }
  </style>
</BaseLayout>
